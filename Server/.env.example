PORT=3001

PRINTAVO_EMAIL=your_printavo_login_email
PRINTAVO_TOKEN=your_printavo_api_token
PRINTAVO_INQUIRY_KEY=your_printavo_inquiry_form_key

# Optional starter accounts used only when Server/data/app-users.json does not exist.
# Keep real usernames and passwords in Server/.env on the deployed server.
DM_ADMIN_USERNAME=
DM_ADMIN_PASSWORD=
DM_ADMIN_DISPLAY_NAME=Admin
DM_BACKUP_ADMIN_USERNAME=
DM_BACKUP_ADMIN_PASSWORD=
DM_BACKUP_ADMIN_DISPLAY_NAME=Backup Admin
DM_INSTALLER_USERNAME=
DM_INSTALLER_PASSWORD=
DM_INSTALLER_DISPLAY_NAME=Installer
